# ── Développement (SQLite, rien à installer) ──────────────
# Laisse cette ligne commentée pour utiliser SQLite automatiquement
# DATABASE_URL=sqlite:///./netfree.db

# ── Production (PostgreSQL) ───────────────────────────────
# Décommente et remplis quand tu passes en production
# DATABASE_URL=postgresql://utilisateur:motdepasse@localhost:5432/netfree

# Exemple avec un hébergeur comme Render ou Railway :
# DATABASE_URL=postgresql://netfree_user:abc123@dpg-xxxx.render.com/netfree_db

# ── Clé API Gigs ──────────────────────────────────────────
GIGS_API_KEY=ta_cle_gigs_sandbox_ici

# ── Sécurité ──────────────────────────────────────────────
SECRET_KEY=change_cette_cle_en_production_avec_une_vraie_valeur_aleatoire
